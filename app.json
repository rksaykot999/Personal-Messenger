{
  "expo": {
    "name": "Personal Messenger",
    "slug": "personal-messenger",
    "version": "4.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "personal-messenger",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.rksaykot999.PersonalMessenger",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Personal Messenger কে ভিডিও কলের জন্য ক্যামেরা ব্যবহার করতে দিন।",
          "microphonePermission": "Personal Messenger কে ভয়েস ও ভিডিও কলের জন্য মাইক্রোফোন ব্যবহার করতে দিন."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fbf72a00-5439-4355-9d2e-851429b2f431"
      }
    },
    "owner": "rksaykot999"
  }
}