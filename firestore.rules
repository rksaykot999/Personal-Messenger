rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // হেল্পার ফাংশন: ইউজার লগইন করা আছে কিনা চেক করে
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Users Collection ---
    match /users/{userId} {
      // ডিসকভার লিস্ট, ফ্রেন্ড সিস্টেম, এবং সিঙ্ক ঠিক রাখতে লগইন করা যেকোনো ইউজারকে রিড/রাইট পারমিশন দেওয়া হলো
      allow read, write: if isAuthenticated();
    }

    // --- Friend Requests Collection ---
    match /friend_requests/{requestId} {
      allow read, write: if isAuthenticated();
    }

    // --- WebRTC Calls Collection ---
    match /calls/{callId} {
      // শুধুমাত্র কল দাতা (caller) এবং কল গ্রহীতা (receiver) যেন ডাটা দেখতে এবং আপডেট করতে পারে
      allow read, update, delete: if isAuthenticated() && (
        request.auth.uid == resource.data.receiverId ||
        request.auth.uid == resource.data.callerId
      );
      // নতুন কল তৈরি করার অনুমতি
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.receiverId ||
        request.auth.uid == request.resource.data.callerId
      );
    }

    // --- Chats Collection ---
    match /chats/{chatId} {
      // পার্টিসিপেন্টরা চ্যাট তৈরি করতে পারবে
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participants;
        
      // চ্যাট লিস্ট ও মেটাডাটা লোড করার জন্য এবং গ্রুপ লিভ/ডিলিট সিঙ্ক ঠিক রাখতে রিড/আপডেট/ডিলিট ওপেন রাখা হলো
      allow read, update, delete: if isAuthenticated();
         
      // --- Nested Messages Subcollection ---
      match /messages/{messageId} {
        // গ্রুপ বা চ্যাট ডিলিট করার সময় যাতে প্যারেন্ট ডকুমেন্ট আগে মুছে গেলেও মেসেজ ডিলিট আটকে না যায়
        allow read, write: if isAuthenticated();
      }
      
      // --- Nested Typing Indicators Subcollection ---
      match /typing/{userId} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}